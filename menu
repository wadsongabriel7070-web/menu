	local lR = Instance.new("Frame", container)
	lR.Size             = UDim2.new(0, LINE_LEN, 0, LINE_THICK)
	lR.AnchorPoint      = Vector2.new(0, 0.5)
	lR.BackgroundColor3 = Color3.fromRGB(255, 70, 70)
	lR.BorderSizePixel  = 0
	lR.ZIndex           = 6
	Instance.new("UICorner", lR).CornerRadius = UDim.new(1, 0)

	local dot = Instance.new("Frame", container)
