	Camera = workspace.CurrentCamera
end)

local ESP_Settings = {
	VisibleColor    = Color3.fromRGB(0, 255, 0),
	HiddenColor     = Color3.fromRGB(255, 0, 0),
	LineThickness   = 1.0,
	KillAllMode     = false,
	MetrosConversao = 3.57,
	BillboardOffset = Vector3.new(0, 3, 0),
}

local ESP_Tracers    = {}
local ESP_Boxes      = {}
local ESP_Chams      = {}
local ESP_Connection = nil

local function ESP_GetTeamID(p)
	return p:GetAttribute("TeamID")
end

local function ESP_IsEnemy(p)
	if ESP_Settings.KillAllMode then return true end
	local myTeam     = Player.Team or ESP_GetTeamID(Player)
	local targetTeam = p.Team     or ESP_GetTeamID(p)
	if myTeam and targetTeam and myTeam == targetTeam then return false end
	return true
end

local function ESP_GetDistanceInMeters(p1, p2)
	local studs = (p1.Position - p2.Position).Magnitude
	return math.floor(studs / ESP_Settings.MetrosConversao)
end

local function ESP_CleanupPlayer(p)
	if ESP_Tracers[p.Name] then
		pcall(function() ESP_Tracers[p.Name].Visible = false end)
		pcall(function() ESP_Tracers[p.Name]:Remove() end)
		ESP_Tracers[p.Name] = nil
	end
	if p.Character then
		local head = p.Character:FindFirstChild("Head")
		if head then
			local b = head:FindFirstChild("EnemyBillboard")
			if b then b:Destroy() end
		end
	end
	if ESP_Boxes[p.Name] then
		pcall(function() ESP_Boxes[p.Name]:Destroy() end)
		ESP_Boxes[p.Name] = nil
	end
	if p.Character then
		local hrp = p.Character:FindFirstChild("HumanoidRootPart")
		if hrp then
			local bx = hrp:FindFirstChild("ESP_Box")
			if bx then bx:Destroy() end
		end
	end
	if ESP_Chams[p.Name] then
		pcall(function() ESP_Chams[p.Name]:Destroy() end)
		ESP_Chams[p.Name] = nil
	end
	if p.Character then
		local hl = p.Character:FindFirstChild("Chams_Highlight")
		if hl then hl:Destroy() end
		EggESP_RemoveFromCharacter(p.Character)
	end
end

local function ESP_Stop()
	if ESP_Connection then ESP_Connection:Disconnect(); ESP_Connection = nil end
	for _, p in pairs(Players:GetPlayers()) do
		ESP_CleanupPlayer(p)
	end
	ESP_Tracers = {}
	ESP_Boxes   = {}
	ESP_Chams   = {}
	EggESP_RemoveAll()
end

local ESP_MAX_DISTANCE_STUDS = 200 * 3.57

local function ESP_Start()
	ESP_Connection = RunService.RenderStepped:Connect(function()
		local cam   = Camera
		if not cam then return end

		local myChar = Player.Character
		local myHRP  = myChar and myChar:FindFirstChild("HumanoidRootPart")

		local showLine     = ESP_CB_Line.GetValue()
		local showBox      = ESP_CB_Box.GetValue()
		local showName     = ESP_CB_Name.GetValue()
		local showDistance = ESP_CB_Distance.GetValue()
		local showChams    = ESP_CB_Chams.GetValue()
		local showEggs     = ESP_CB_Eggs.GetValue()

		for _, p in pairs(Players:GetPlayers()) do
			if p ~= Player
				and p.Character
				and p.Character:FindFirstChild("HumanoidRootPart")
				and p.Character:FindFirstChild("Head") then

				local hrpEnemy = p.Character.HumanoidRootPart
				if myHRP then
					local studs = (hrpEnemy.Position - myHRP.Position).Magnitude
					if studs > ESP_MAX_DISTANCE_STUDS then
						ESP_CleanupPlayer(p)
						continue
					end
				end

				if ESP_IsEnemy(p) then
					local head = p.Character.Head
					local hrp  = p.Character.HumanoidRootPart

					if showChams then
						if not ESP_Chams[p.Name] or not ESP_Chams[p.Name].Parent then
							local old = p.Character:FindFirstChild("Chams_Highlight")
							if old then old:Destroy() end
							local hl = Instance.new("Highlight")
							hl.Name                = "Chams_Highlight"
							hl.FillColor           = Color3.fromRGB(255, 85, 0)
							hl.FillTransparency    = 0.5
							hl.OutlineColor        = Color3.fromRGB(255, 255, 255)
							hl.OutlineTransparency = 0
							hl.DepthMode           = Enum.HighlightDepthMode.AlwaysOnTop
							hl.Parent              = p.Character
							ESP_Chams[p.Name]      = hl
						end
					else
						if ESP_Chams[p.Name] then
							pcall(function() ESP_Chams[p.Name]:Destroy() end)
							ESP_Chams[p.Name] = nil
						end
						local old = p.Character:FindFirstChild("Chams_Highlight")
						if old then old:Destroy() end
					end

					if showBox then
						local existingBox = hrp:FindFirstChild("ESP_Box")
						if not existingBox then
							local billboard       = Instance.new("BillboardGui")
							billboard.Name        = "ESP_Box"
							billboard.Adornee     = hrp
							billboard.AlwaysOnTop = true
							billboard.Size        = UDim2.new(4.5, 0, 6, 0)
							billboard.ExtentsOffset = Vector3.new(0, 0, 0)
							billboard.Parent      = hrp
							ESP_Boxes[p.Name]     = billboard

							local frame = Instance.new("Frame")
							frame.Size  = UDim2.new(1, 0, 1, 0)
							frame.BackgroundTransparency = 1
							frame.Parent = billboard

							local stroke = Instance.new("UIStroke")
							stroke.Thickness       = 2
							stroke.Color           = Color3.fromRGB(255, 85, 0)
							stroke.ApplyStrokeMode = Enum.ApplyStrokeMode.Border
							stroke.Transparency    = 0.3
							stroke.Parent          = frame
						else
							local sizeVec = p.Character:GetExtentsSize()
							existingBox.Size = UDim2.new(sizeVec.X * 0.8, 0, sizeVec.Y * 1.1, 0)
						end
					else
						if ESP_Boxes[p.Name] then
							pcall(function() ESP_Boxes[p.Name]:Destroy() end)
							ESP_Boxes[p.Name] = nil
						end
						local bx = hrp:FindFirstChild("ESP_Box")
						if bx then bx:Destroy() end
					end

					if showEggs then
						if not p.Character:FindFirstChild("EggESP") then
							EggESP_CreateForCharacter(p.Character)
						end
					else
						EggESP_RemoveFromCharacter(p.Character)
					end

					local billboardWorldPos = head.Position + ESP_Settings.BillboardOffset
					local vector, onScreen  = cam:WorldToViewportPoint(billboardWorldPos)

					if onScreen then
						local rayParams = RaycastParams.new()
						rayParams.FilterDescendantsInstances = {myChar, cam}
						rayParams.FilterType = Enum.RaycastFilterType.Exclude
						local ray = workspace:Raycast(
							cam.CFrame.Position,
							(head.Position - cam.CFrame.Position),
							rayParams
						)
						local isVisible    = not ray or ray.Instance:IsDescendantOf(p.Character)
						local currentColor = isVisible and ESP_Settings.VisibleColor or ESP_Settings.HiddenColor

						if showLine then
							if not ESP_Tracers[p.Name] then
								local line          = Drawing.new("Line")
								line.Thickness      = ESP_Settings.LineThickness
								line.Transparency   = 1
								ESP_Tracers[p.Name] = line
							end
							local line   = ESP_Tracers[p.Name]
							line.Color   = currentColor
							line.From    = Vector2.new(cam.ViewportSize.X / 2, 0)
							line.To      = Vector2.new(vector.X, vector.Y)
							line.Visible = true
						else
							if ESP_Tracers[p.Name] then
								ESP_Tracers[p.Name].Visible = false
							end
						end

						if showName or showDistance then
							local b = head:FindFirstChild("EnemyBillboard")
							if not b then
								b             = Instance.new("BillboardGui", head)
								b.Name        = "EnemyBillboard"
								b.AlwaysOnTop = true
								b.Size        = UDim2.new(0, 150, 0, 50)
								b.StudsOffset = ESP_Settings.BillboardOffset
								local t = Instance.new("TextLabel", b)
								t.Name                   = "InfoLabel"
								t.BackgroundTransparency = 1
								t.Size                   = UDim2.new(1, 0, 1, 0)
								t.Font                   = Enum.Font.GothamBold
								t.TextSize               = 14
								t.TextStrokeTransparency = 0
							end
							local label = b:FindFirstChild("InfoLabel")
							if label then
								local metros   = myHRP and ESP_GetDistanceInMeters(myHRP, hrp) or 0
								local namePart = showName and p.Name or ""
								local distPart = showDistance and string.format("[%d Metros]", metros) or ""
								if showName and showDistance then
									label.Text = namePart .. "\n" .. distPart
								elseif showName then
									label.Text = namePart
								else
									label.Text = distPart
								end
								label.TextColor3 = currentColor
							end
						else
							local b = head:FindFirstChild("EnemyBillboard")
							if b then b:Destroy() end
						end
					else
						if ESP_Tracers[p.Name] then
							ESP_Tracers[p.Name].Visible = false
						end
					end
				else
					ESP_CleanupPlayer(p)
				end
			else
				ESP_CleanupPlayer(p)
			end
		end
	end)
end

