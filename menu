local DarkMap_OriginalValues = {}
local DarkMap_Active = false

local function DarkMap_Start()
	if DarkMap_Active then return end
	DarkMap_Active = true

	DarkMap_OriginalValues = {
		Ambient        = Lighting.Ambient,
		OutdoorAmbient = Lighting.OutdoorAmbient,
		Brightness     = Lighting.Brightness,
		FogEnd         = Lighting.FogEnd,
		FogColor       = Lighting.FogColor,
	}

	local old = Lighting:FindFirstChild("DarkFX_CC")
	if old then old:Destroy() end

	local cc = Instance.new("ColorCorrectionEffect")
	cc.Name        = "DarkFX_CC"
	cc.Brightness  = -0.55
	cc.Contrast    = 0.2
	cc.Saturation  = -0.3
	cc.TintColor   = Color3.fromRGB(60, 60, 100)
	cc.Parent      = Lighting

	TweenService:Create(Lighting, TweenInfo.new(1.2, Enum.EasingStyle.Sine), {
		Ambient        = Color3.fromRGB(0, 0, 0),
		OutdoorAmbient = Color3.fromRGB(0, 0, 0),
		Brightness     = 0,
		FogEnd         = 60,
		FogColor       = Color3.fromRGB(8, 8, 16),
	}):Play()
end

local function DarkMap_Stop()
	if not DarkMap_Active then return end
	DarkMap_Active = false

	local cc = Lighting:FindFirstChild("DarkFX_CC")
	if cc then
		TweenService:Create(cc, TweenInfo.new(1.0, Enum.EasingStyle.Sine), {Brightness = 0}):Play()
		task.delay(1.1, function() if cc and cc.Parent then cc:Destroy() end end)
	end
	TweenService:Create(Lighting, TweenInfo.new(1.2, Enum.EasingStyle.Sine), {
		Ambient        = DarkMap_OriginalValues.Ambient        or Color3.fromRGB(70,70,70),
		OutdoorAmbient = DarkMap_OriginalValues.OutdoorAmbient or Color3.fromRGB(140,140,140),
		Brightness     = DarkMap_OriginalValues.Brightness     or 1,
		FogEnd         = DarkMap_OriginalValues.FogEnd         or 100000,
		FogColor       = DarkMap_OriginalValues.FogColor       or Color3.fromRGB(191,191,191),
	}):Play()
end

