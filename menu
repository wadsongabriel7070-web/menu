		CrossAngle = (CrossAngle + ROT_SPEED * dt) % 360
		container.Rotation = CrossAngle

		pulseT = pulseT + dt * PULSE_SPD
		local gap = PULSE_MIN + (PULSE_MAX - PULSE_MIN) * ((math.sin(pulseT * math.pi * 2) + 1) / 2)

		rainbowT = rainbowT + dt
		local rc = RainbowColor(rainbowT)
		lU.BackgroundColor3 = rc
		lD.BackgroundColor3 = rc
		lL.BackgroundColor3 = rc
		lR.BackgroundColor3 = rc

		local cx, cy = 0.5, 0.5
		lU.Position = UDim2.new(cx, 0, cy, -(gap))
		lD.Position = UDim2.new(cx, 0, cy, gap)
		lL.Position = UDim2.new(cx, -(gap), cy, 0)
		lR.Position = UDim2.new(cx, gap, cy, 0)
	end)
end

