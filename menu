--   NEVE 2D — Azul Neon escuro igual à GUI
-- =============================================
local SnowSG     = nil
local SnowConn   = nil
local SnowFlakes = {}
local SNOW_COUNT = 160

local SNOW_COLORS = {
	Color3.fromRGB(99,  102, 241),
	Color3.fromRGB(139, 92,  246),
	Color3.fromRGB(80,  90,  230),
	Color3.fromRGB(110, 120, 255),
	Color3.fromRGB(60,  70,  200),
}

local function Snow_NewFlake(parent, randomY)
	local roll = math.random(1, 10)
	local size
	if roll <= 5 then size = math.random(1, 2)
	elseif roll <= 8 then size = math.random(3, 4)
	else size = 5 end

	local alpha   = math.random(50, 95) / 100
	local speedY  = math.random(25, 90)
	local speedX  = math.random(-20, 20)
	local spinSpd = math.random(-200, 200)
	local startX  = math.random(0, 10000) / 10000
	local startY  = randomY and (math.random(-20, 100) / 100) or (-size / 1080)
	local chosenColor = SNOW_COLORS[math.random(1, #SNOW_COLORS)]

	local flake = Instance.new("Frame")
	flake.Size             = UDim2.new(0, size, 0, size)
	flake.Position         = UDim2.new(startX, 0, startY, 0)
	flake.BackgroundColor3 = chosenColor
	flake.BackgroundTransparency = 1 - alpha
	flake.BorderSizePixel  = 0
	flake.ZIndex           = 3
	flake.Parent           = parent
	Instance.new("UICorner", flake).CornerRadius = UDim.new(1, 0)

	return {
		frame  = flake,
		x      = startX,
		y      = startY,
		speedY = speedY,
		speedX = speedX,
		spin   = spinSpd,
		rot    = math.random(0, 360),
		size   = size,
	}
end

local function Snow_Start()
	if SnowSG then pcall(function() SnowSG:Destroy() end) end
	SnowSG = Instance.new("ScreenGui")
	SnowSG.Name           = "SnowFX"
	SnowSG.ResetOnSpawn   = false
	SnowSG.IgnoreGuiInset = true
	SnowSG.DisplayOrder   = 999999980
	SafeParentGui(SnowSG)

	local overlay = Instance.new("Frame")
	overlay.Size                   = UDim2.new(1, 0, 1, 0)
	overlay.BackgroundColor3       = Color3.fromRGB(20, 20, 60)
	overlay.BackgroundTransparency = 0.97
	overlay.BorderSizePixel        = 0
	overlay.ZIndex                 = 1
	overlay.Parent                 = SnowSG

	local container = Instance.new("Frame")
	container.Size                   = UDim2.new(1, 0, 1, 0)
	container.BackgroundTransparency = 1
	container.BorderSizePixel        = 0
	container.ZIndex                 = 2
	container.ClipsDescendants       = true
	container.Parent                 = SnowSG

	SnowFlakes = {}
	for i = 1, SNOW_COUNT do
		table.insert(SnowFlakes, Snow_NewFlake(container, true))
	end

	SnowConn = RunService.RenderStepped:Connect(function(dt)
		local cam = workspace.CurrentCamera
		if not cam then return end
		local vp  = cam.ViewportSize
		local w, h = vp.X, vp.Y
		if w == 0 or h == 0 then return end

		for _, f in ipairs(SnowFlakes) do
			f.y   = f.y + (f.speedY / h) * dt
			f.x   = f.x + (f.speedX / w) * dt
			f.rot = f.rot + f.spin * dt

			if f.y > 1.02 then
				f.y = -(f.size / h)
				f.x = math.random(0, 10000) / 10000
			end
			if f.x > 1.02 then f.x = -(f.size / w) end
			if f.x < -(f.size / w) then f.x = 1.01 end

			f.frame.Position = UDim2.new(f.x, 0, f.y, 0)
			f.frame.Rotation = f.rot
		end
	end)
end

local function Snow_Stop()
	if SnowConn  then SnowConn:Disconnect();  SnowConn  = nil end
	SnowFlakes = {}
	if SnowSG   then pcall(function() SnowSG:Destroy() end); SnowSG = nil end
end

